# Configurações obrigatórias do StackSpot AI
STACKSPOT_CLIENT_ID="seu_client_id_aqui"
STACKSPOT_CLIENT_SECRET="seu_client_secret_aqui"
STACKSPOT_REALM="seu_realm_aqui"
STACKSPOT_AGENT_ID="seu_agent_id_aqui"

# Opcional: URL da API (padrão é a oficial da StackSpot)
# STACKSPOT_API_URL="https://genai-code-buddy-api.stackspot.com"

# Nível de log (DEBUG para ver os payloads de comunicação)
LOG_LEVEL="DEBUG"
